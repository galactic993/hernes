# Copy to .env and fill in. NEVER commit real secrets (see docs/constitution.md).

# --- AI agent CLI ------------------------------------------------------------
# scripts/ がエージェントを非対話で呼ぶときのコマンド。
# 例: "codex exec"  |  "claude -p"
AGENT_CMD="codex exec"

# ループ安全装置
MAX_ATTEMPTS=3

# --- 設計書レンダリング（任意） ----------------------------------------------
# scripts/render-design.sh の解像度。読みづらければ 200 などに上げる。
DPI=150

# --- App config (例：実プロジェクトで置換) -----------------------------------
# DATABASE_URL=postgres://...
# PORT=8787
