# Copy to .env and fill in. NEVER commit real secrets (see docs/constitution.md).
#
# このファイルは「ローカル開発専用」。本番/staging/preview のランタイム secret
# （DATABASE_URL / CLERK_SECRET_KEY / CLERK_WEBHOOK_SECRET / APP_SECRET / REDIS_AUTH_STRING 等）は
# .env には書かず、GCP Secret Manager が source of truth。Cloud Run は --update-secrets で参照する
# （詳細は docs/development-harness.md §11-12）。
# .env に入れるのは AI 自動開発ループの設定とローカルアプリ設定だけ。

# --- AI agent CLI ------------------------------------------------------------
# scripts/ がエージェントを非対話で呼ぶときのコマンド。
# 例: "codex exec"  |  "claude -p"
AGENT_CMD="codex exec"

# ループ安全装置
MAX_ATTEMPTS=3

# --- 設計書レンダリング（任意） ----------------------------------------------
# scripts/render-design.sh の解像度。読みづらければ 200 などに上げる。
DPI=150

# --- App config (例：実プロジェクトで置換) -----------------------------------
# DATABASE_URL=postgres://...
# PORT=8787
