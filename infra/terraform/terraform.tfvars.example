# terraform.tfvars.example
# コピーして terraform.tfvars を作り、値を埋める。
#   cp terraform.tfvars.example terraform.tfvars
# terraform.tfvars は .gitignore 済みであることを確認すること（機密ではないが project 固有）。

# ---- 共通 -------------------------------------------------------------------
app_name = "hernes"
region   = "asia-northeast1"

# ---- プロジェクト -----------------------------------------------------------
# 単一 project 運用ならこれだけでよい（dev/preview/staging/prod 全部ここに乗る）。
project_id = "hernes-dev-123456"

# 環境ごとに project を分ける場合だけ以下を指定（空ならフォールバック）。
# project_id_staging    = "hernes-staging-123456"
# project_id_production = "hernes-prod-123456"

# ---- GitHub / WIF -----------------------------------------------------------
github_repository = "your-org/hernes"

# ---- 環境フラグ -------------------------------------------------------------
# preview は GitHub Actions が動的に作るので Terraform 管理対象外（フラグ無し）。
enable_staging    = true
enable_production = false

# ---- Cloud SQL --------------------------------------------------------------
db_tier_staging    = "db-custom-1-3840"
db_tier_production = "db-custom-2-7680"
db_name            = "hernes"
# PostgreSQL バージョンは modules/cloud-sql 側で固定（POSTGRES_16）。ここでは指定不要。
#
# アプリ DB「ユーザパスワード」は Terraform の provisioning 入力（機密）。google_sql_user 作成に
# 必要なため Terraform が受け取る。これは「Terraform は Secret Manager の runtime 値を扱わない」
# 規約とは別レイヤ。tfvars に実値を書かず、環境変数で out-of-band に注入する:
#   read -rs -p "staging DB password: " TF_VAR_db_app_password_staging && export TF_VAR_db_app_password_staging
#   （パスワードマネージャ CLI でも可: TF_VAR_db_app_password_staging="$(op read 'op://…')"）
# 注意: これは DB ユーザのパスワードであり runtime の DATABASE_URL とは別物。<env>-database-url は流用しない。
#   apply 後に private IP + このパスワードから DATABASE_URL を組み立て、<env>-database-url に格納する（README 参照）。

# ---- Memorystore (Redis) ----------------------------------------------------
redis_tier           = "BASIC"
redis_memory_size_gb = 1

# ---- ネットワーク -----------------------------------------------------------
network_subnet_cidr = "10.8.0.0/24"

# ---- 監視（Cloud Monitoring / Logging / Billing budget）---------------------
enable_monitoring      = true
# 初回構築時のみ true にして API を有効化（以降は別管理なら false に戻してよい）。
enable_monitoring_apis = false
# アラート・予算の通知先。最低 1 件は設定推奨。
notification_emails    = ["oncall@example.com"]

# 任意: アラート fan-out 用 Pub/Sub トピック。
# monitoring_pubsub_topic = "projects/hernes-dev-123456/topics/hernes-alerts"

# 料金: 予算は production を含む監視インスタンスにのみ作られる（通知のみ・支出は止めない）。
# billing_account は請求アカウント ID（project_id ではない！）。空なら予算なし。
# billing_account                = "XXXXXX-XXXXXX-XXXXXX"
# monitoring_budget_amount_units = 50000

# 任意: 外形監視（安定したカスタムドメインがある場合のみ）。
# uptime_targets = {
#   production = { app = { host = "app.example.com", path = "/healthz" } }
# }
